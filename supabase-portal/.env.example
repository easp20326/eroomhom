# Supabase 프로젝트 설정
# https://supabase.com → 프로젝트 → Settings → API에서 확인 가능

# ① Supabase URL (Project URL)
# 예: https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=https://your-project.supabase.co

# ② Supabase anon/public key (Project API keys → anon public)
# ⚠️ 이 키는 브라우저에 공개되므로 권한 설정으로 보호하세요
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
